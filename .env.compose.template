# Absolute path to this NanoClaw checkout on the Docker host.
# This must be the same checkout used to build the host image.
NANOCLAW_HOST_PATH=/absolute/path/to/nanoclaw

# Docker socket group id on the host.
# macOS: stat -f '%g' /var/run/docker.sock
# Linux: stat -c '%g' /var/run/docker.sock
DOCKER_GID=0

# Host config directory mounted into /home/node/.config/nanoclaw
NANOCLAW_CONFIG_DIR=/absolute/path/to/.config/nanoclaw

# Shared temp directory for OneCLI CA files.
# Keep the same absolute path on host and in the container.
NANOCLAW_SHARED_TMP=/tmp/nanoclaw-shared

# Compose network name used by nanoclaw-agent sibling containers.
NANOCLAW_DOCKER_NETWORK=nanoclaw-compose

# Build hash used to invalidate cached per-group agent-runner copies.
# Set this to the current git commit before building.
NANOCLAW_BUILD_HASH=dev

COMPOSE_CONTAINER_IMAGE=nanoclaw-agent:latest
COMPOSE_ONECLI_DASHBOARD_PORT=10254
COMPOSE_ONECLI_GATEWAY_PORT=10255
COMPOSE_POSTGRES_USER=onecli
COMPOSE_POSTGRES_PASSWORD=onecli
COMPOSE_POSTGRES_DB=onecli
