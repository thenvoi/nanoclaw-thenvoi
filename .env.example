
# Thenvoi Platform Channel
# Connect NanoClaw to the Thenvoi Platform as a messaging channel.
# Register as an external agent on the platform to get these credentials.
# THENVOI_BASE_URL=https://app.thenvoi.com
# THENVOI_AGENT_ID=your-agent-uuid
# THENVOI_API_KEY=your-api-key

# Thenvoi Contact Event Strategy
# disabled — log contact events, manual query only (default)
# callback — auto-approve all incoming contact requests
# hub_room — dedicated chat room where the LLM evaluates requests
# THENVOI_CONTACT_STRATEGY=disabled

# Platform owner user ID (for hub_room strategy).
# Auto-derived from agent profile if not set.
# THENVOI_OWNER_ID=
